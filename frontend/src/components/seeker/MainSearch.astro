---
// src/components/seeker/MainSearch.astro
---

<div class="trigger-zone" id="interactive-zone">
  
  <div class="search-box-wrapper" id="search-wrapper">
    <input type="text" placeholder="¿Qué estás buscando?..." class="search-input" />
    <button class="search-btn">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
    </button>
  </div>

  <div class="eye-wrapper" id="eye-wrapper">
    <div class="eye" id="eye-element">
      <div class="pupil"></div>
    </div>
  </div>

  <div class="brand-wrapper" id="brand-wrapper">
    <h1 class="brand-text">
      <span class="first-name">Santiago</span> 
      <span class="last-name">Crescimbeni</span>
    </h1>
  </div>

  <div class="flash-overlay" id="flash-effect"></div>
</div>

<script>
  const interactiveZone = document.getElementById('interactive-zone');
  const searchWrapper = document.getElementById('search-wrapper');
  const eyeWrapper = document.getElementById('eye-wrapper');
  const eyeElement = document.getElementById('eye-element');
  const brandWrapper = document.getElementById('brand-wrapper');
  const flashEffect = document.getElementById('flash-effect');

  // Variable de control para evitar interrupciones mientras corre la animación
  let isAnimating = false;

  if (interactiveZone && searchWrapper && eyeWrapper && eyeElement && brandWrapper && flashEffect) {
    
    // 1. REVELAR BUSCADOR (Al posicionar el mouse encima)
    interactiveZone.addEventListener('mouseenter', () => {
      if (isAnimating) return; // Bloquea el hover si la animación de salida está activa

      // Aseguramos limpieza de estados previos
      interactiveZone.classList.remove('fade-out-fast');
      brandWrapper.classList.remove('active', 'glow');
      eyeWrapper.classList.remove('active');
      eyeElement.classList.remove('wink');
      
      // Muestra el buscador con total nitidez
      searchWrapper.classList.add('active');
    });

    // 2. DISPARAR SECUENCIA (Al quitar el mouse)
    interactiveZone.addEventListener('mouseleave', () => {
      if (!searchWrapper.classList.contains('active') || isAnimating) return;
      
      isAnimating = true;

      // Desvanecer el buscador por completo
      searchWrapper.classList.remove('active');
      
      // Aparece el ojo tras ocultarse el buscador
      setTimeout(() => {
        eyeWrapper.classList.add('active');
        
        // Guiño rápido
        setTimeout(() => {
          eyeElement.classList.add('wink');
          
          // Flash instantáneo en el pico del guiño
          setTimeout(() => {
            flashEffect.classList.add('trigger');
            
            // Reemplazo del ojo por tu firma elegante en medio del destello blanco
            eyeWrapper.classList.remove('active');
            brandWrapper.classList.add('active', 'glow');
            
            // El flash se disipa
            setTimeout(() => {
              flashEffect.classList.remove('trigger');
              
              // DEGRADADO RÁPIDO: Desvanecer todo el contenedor a la vez (Buscador, Ojo y Nombre)
              setTimeout(() => {
                interactiveZone.classList.add('fade-out-fast');
                
                // RESET TOTAL FINAL: Permite volver a repetir la acción limpiando los estados
                setTimeout(() => {
                  brandWrapper.classList.remove('active', 'glow');
                  eyeElement.classList.remove('wink');
                  interactiveZone.classList.remove('fade-out-fast');
                  isAnimating = false; // Desbloqueado para la próxima entrada del cursor
                }, 400); // Espera a que termine la opacidad de CSS del fade-out-fast

              }, 1200); // Tiempo de exposición de tu nombre en pantalla

            }, 150);
            
          }, 100);
          
        }, 150);
        
      }, 200);
    });
  }
</script>

<style>
  /* Contenedor central flexible */
  .trigger-zone {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 10;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    max-width: 600px;
    height: 200px;
    background: transparent;
    transition: opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  /* Degradado rápido hacia la nada */
  .trigger-zone.fade-out-fast {
    opacity: 0;
  }

  /* ==================== 1. EL BUSCADOR ==================== */
  .search-box-wrapper {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(0, 242, 254, 0.1);
    border-radius: 30px;
    padding: 6px 6px 6px 20px;
    width: 90%;
    backdrop-filter: blur(12px);
    
    /* CORRECCIÓN: Desaparece por completo al inicio */
    opacity: 0;
    visibility: hidden; 
    
    transform: scale(0.96);
    transition: opacity 0.25s ease, transform 0.25s ease, visibility 0.25s, border-color 0.25s, box-shadow 0.25s;
    cursor: pointer; /* Mano al posicionarse sobre el buscador */
  }

  .search-box-wrapper.active {
    opacity: 1;
    visibility: visible;
    transform: scale(1);
    border-color: #00f2fe;
    box-shadow: 0 0 25px rgba(0, 242, 254, 0.25);
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: #ffffff;
    font-size: 1rem;
    font-family: system-ui, -apple-system, sans-serif;
    cursor: text; /* El input mantiene cursor de escritura */
  }

  .search-btn {
    background: #00f2fe;
    border: none;
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    justify-content: center;
    align-items: center;
    color: #060608;
    cursor: pointer;
    transition: transform 0.2s, background-color 0.2s;
  }

  .search-btn:hover {
    transform: scale(1.05);
    background: #ffffff;
  }

  /* ==================== 2. EL OJO DE IA ==================== */
  .eye-wrapper {
    position: absolute;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.7);
    transition: all 0.25s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .eye-wrapper.active {
    opacity: 1;
    transform: scale(1);
  }

  .eye {
    width: 65px;
    height: 36px;
    border: 2px solid #ffffff;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: hidden;
    transition: height 0.1s ease-in-out;
  }

  .pupil {
    width: 18px;
    height: 18px;
    background: #00f2fe;
    border-radius: 50%;
    box-shadow: 0 0 10px #00f2fe;
  }

  .eye.wink {
    height: 1px;
  }

  /* ==================== 3. SANTIAGO CRESCIMBENI (ELEGANTE) ==================== */
  .brand-wrapper {
    position: absolute;
    pointer-events: none;
    opacity: 0;
    transform: scale(0.95);
    transition: opacity 0.3s ease, transform 0.3s ease;
    text-align: center;
    width: 100%;
  }

  .brand-wrapper.active {
    opacity: 1;
    transform: scale(1);
  }

  .brand-text {
    font-family: system-ui, -apple-system, sans-serif;
    font-size: 2.2rem;
    font-weight: 300;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin: 0;
    color: #ffffff;
    transition: filter 0.4s ease;
  }

  /* Combinación tipográfica formal y tecnológica */
  .first-name {
    color: #ffffff;
    font-weight: 300;
  }

  .last-name {
    color: #00f2fe;
    font-weight: 600;
  }

  /* Brillo sutil y limpio */
  .brand-wrapper.glow .brand-text {
    filter: drop-shadow(0 0 8px rgba(0, 242, 254, 0.6)) drop-shadow(0 0 20px rgba(0, 242, 254, 0.2));
  }

  /* ==================== 4. FLASH DE CÁMARA ==================== */
  .flash-overlay {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 300vw;
    height: 300vh;
    background: #ffffff;
    pointer-events: none;
    opacity: 0;
    z-index: 999;
  }

  .flash-overlay.trigger {
    animation: instantFlash 0.18s ease-out forwards;
  }

  @keyframes instantFlash {
    0% { opacity: 0; }
    15% { opacity: 1; }
    100% { opacity: 0; }
  }
</style>