---
import './MainSearch.css';
---

<div>
  <div class="trigger-zone" id="interactive-zone">
    
    <div class="search-box-wrapper" id="search-wrapper">
      <input type="text" id="search-input" placeholder="What would you like to know about me?..." class="search-input" />
      <button id="search-button" class="search-btn">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
    </div>

    <div class="eye-wrapper" id="eye-wrapper">
      <div class="eye" id="eye-element">
        <div class="pupil"></div>
      </div>
    </div>

    <div class="brand-wrapper" id="brand-wrapper">
      <h1 class="brand-text">
        <span class="first-name">Santiago</span> 
        <span class="last-name">Crescimbeni</span>
      </h1>
    </div>

    <div class="flash-overlay" id="flash-effect"></div>
  </div>

  <div id="response-container" class="ai-response-box-fixed"></div>
</div>

<script>
  import './MainSearch.ts';
</script>